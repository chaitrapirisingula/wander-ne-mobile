{
  "cli": {
    "version": ">= 13.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal"
    },
    "preview": {
      "environment": "preview",
      "distribution": "internal",
      "ios": {
        "simulator": false
      }
    },
    "production": {
      "environment": "production",
      "autoIncrement": true,
      "ios": {
        "resourceClass": "large"
      }
    }
  }
}
